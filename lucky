-- Toggle
local function makeToggle(parent, title, desc, default, callback, order)
    local container = new("Frame", parent, {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        LayoutOrder = order,
        BorderSizePixel = 0,
    })

    new("TextLabel", container, {
        Position = UDim2.new(0, 0, 0, 2),
        Size = UDim2.new(1, -54, 0, 18),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = C.Text,
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    new("TextLabel", container, {
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, -54, 0, 14),
        BackgroundTransparency = 1,
        Text = desc,
        TextColor3 = C.TextSub,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })

    -- Toggle switch background
    local switch = new("Frame", container, {
        Position = UDim2.new(1, -48, 0.5, -11),
        Size = UDim2.new(0, 40, 0, 22),
        BackgroundColor3 = C.ToggleOff,
        BorderSizePixel = 0,
    })
    new("UICorner", switch, { CornerRadius = UDim.new(0, 11) })

    -- Toggle circle
    local circle = new("Frame", switch, {
        Size = UDim2.new(0, 18, 0, 18),
        BackgroundColor3 = C.TextSub,
        BorderSizePixel = 0,
    })
    new("UICorner", circle, { CornerRadius = UDim.new(0, 9) })

    -- Hidden button for interaction
    local btn = new("TextButton", switch, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 5,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })

    local isOn = default

    local function updateVisual()
        local goalBg = isOn and C.ToggleOn or C.ToggleOff
        local goalCircle = isOn and Color3.fromRGB(255, 255, 255) or C.TextSub
        local goalPos = isOn and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        tw(switch, 0.2, { BackgroundColor3 = goalBg })
        tw(circle, 0.2, { BackgroundColor3 = goalCircle, Position = goalPos })
    end

    updateVisual()

    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        updateVisual()
        callback(isOn)
    end)

    return container, {
        setState = function(val)
            isOn = val
            updateVisual()
            callback(val)
        end,
        getState = function() return isOn end,
    }
end

