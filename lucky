        BackgroundColor3 = C.Card,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        LayoutOrder = 1,
    })
    new("UICorner", header, { CornerRadius = UDim.new(0, 8) })
    new("UIStroke", header, { Color = C.Border, Thickness = 1 })

    -- Selected text
    local selectedLabel = new("TextLabel", header, {
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -30, 1, 0),
        BackgroundTransparency = 1,
        Text = default,
        TextColor3 = C.Text,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Arrow
    local arrow = new("TextLabel", header, {
        Position = UDim2.new(1, -24, 0, 0),
        Size = UDim2.new(0, 24, 1, 0),
        BackgroundTransparency = 1,
        Text = "\u{25BC}",
        TextColor3 = C.TextSub,
        TextSize = 12,
        Font = Enum.Font.Gotham,
    })

    -- Options container (flows inside wrapper, pushes content below)
    local optionsFrame = new("Frame", wrapper, {
        Size = UDim2.new(1, 0, 0, #options * 32),
        BackgroundColor3 = C.Card,
        Visible = false,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        LayoutOrder = 2,
    })
    new("UICorner", optionsFrame, { CornerRadius = UDim.new(0, 8) })
    new("UIStroke", optionsFrame, { Color = C.Border, Thickness = 1 })

    local isOpen = false

    local function close()
        isOpen = false
        optionsFrame.Visible = false
        arrow.Text = "\u{25BC}"
    end

    for i, opt in ipairs(options) do
        local optBtn = new("TextButton", optionsFrame, {
            Position = UDim2.new(0, 4, 0, (i - 1) * 32 + 1),
            Size = UDim2.new(1, -8, 0, 30),
            BackgroundColor3 = C.Card,
            Text = opt,
            TextColor3 = C.Text,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            BorderSizePixel = 0,
            AutoButtonColor = false,
        })

        optBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                optBtn.BackgroundColor3 = C.CardHover
            end
        end)

        optBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                optBtn.BackgroundColor3 = C.Card
            end
        end)

        optBtn.MouseButton1Click:Connect(function()
            selectedLabel.Text = opt
            callback(opt)
            close()
            local idx = table.find(openDropdowns, close)
            if idx then table.remove(openDropdowns, idx) end
        end)
    end

    header.MouseButton1Click:Connect(function()
        local wasOpen = isOpen

        -- Close all other open dropdowns
        local toClose = { table.unpack(openDropdowns) }
        for _, fn in ipairs(toClose) do
            fn()
        end
        openDropdowns = {}

        -- Toggle this dropdown
        if not wasOpen then
            isOpen = true
            optionsFrame.Visible = true
            arrow.Text = "\u{25B2}"
            table.insert(openDropdowns, close)
        end
    end)

    return wrapper
end

-- ========== ESP SYSTEM ==========
local function createESPForPlayer(targetPlayer)
    if targetPlayer == player then return end
    if espObjects[targetPlayer] then return end

    local function setupESP()
        if not targetPlayer.Character then return end
        local hrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Remove old ESP objects if any
        if espObjects[targetPlayer] then
            if espObjects[targetPlayer].highlight and espObjects[targetPlayer].highlight.Parent then
                espObjects[targetPlayer].highlight:Destroy()
            end
            if espObjects[targetPlayer].billboard and espObjects[targetPlayer].billboard.Parent then
                espObjects[targetPlayer].billboard:Destroy()
            end
        end

        -- Highlight (box ESP)
        local highlight = new("Highlight", targetPlayer.Character, {
            Name = "SheitsaESP",
            FillTransparency = 0.8,
            OutlineColor = Color3.fromRGB(255, 50, 50),
            FillColor = Color3.fromRGB(255, 50, 50),
            OutlineTransparency = 0,
        })

        -- Billboard for name + distance
        local billboard = new("BillboardGui", hrp, {
            Name = "SheitsaESP_Info",
            Size = UDim2.new(0, 200, 0, 50),
            StudsOffset = Vector3.new(0, 4, 0),
            AlwaysOnTop = true,
        })

        local nameLabel = new("TextLabel", billboard, {
            Size = UDim2.new(1, 0, 0.5, 0),
            BackgroundTransparency = 1,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextStrokeTransparency = 0.3,
            TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            Text = targetPlayer.DisplayName,
        })

        local infoLabel = new("TextLabel", billboard, {
            Size = UDim2.new(1, 0, 0.5, 0),
            Position = UDim2.new(0, 0, 0.5, 0),
            BackgroundTransparency = 1,
            TextColor3 = Color3.fromRGB(200, 200, 200),
            TextStrokeTransparency = 0.3,
            TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
            TextSize = 11,
            Font = Enum.Font.Gotham,
            Text = targetPlayer.Name .. " | --m",
        })

        espObjects[targetPlayer] = {
            highlight = highlight,
            billboard = billboard,
            nameLabel = nameLabel,
            infoLabel = infoLabel,
        }
    end

    -- Setup if character exists
    if targetPlayer.Character then
        setupESP()
    end

    -- Listen for new characters
    espCharConns[targetPlayer] = targetPlayer.CharacterAdded:Connect(function(c)
        task.wait(1)
        setupESP()
    end)
end

local function removeESPForPlayer(targetPlayer)
    local obj = espObjects[targetPlayer]
    if obj then
        if obj.highlight and obj.highlight.Parent then obj.highlight:Destroy() end
        if obj.billboard and obj.billboard.Parent then obj.billboard:Destroy() end
        espObjects[targetPlayer] = nil
    end
    if espCharConns[targetPlayer] then
        espCharConns[targetPlayer]:Disconnect()
        espCharConns[targetPlayer] = nil
    end
end

local function clearAllESP()
    for p, _ in pairs(espObjects) do
        removeESPForPlayer(p)
    end
    espObjects = {}
    espCharConns = {}
end

local function enableESP()
    espEnabled = true
    -- Add ESP to all current players
    for _, p in ipairs(Players:GetPlayers()) do
        createESPForPlayer(p)
    end
    -- Listen for new players
    if espUpdateConn then espUpdateConn:Disconnect() end
    espUpdateConn = RunService.RenderStepped:Connect(function()
        if not espEnabled then return end
        local myChar = player.Character
        local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHrp then return end
        for p, obj in pairs(espObjects) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = math.floor((p.Character.HumanoidRootPart.Position - myHrp.Position).Magnitude)
                obj.infoLabel.Text = p.Name .. " | " .. dist .. "m"
            end
        end
    end)
end

local function disableESP()
    espEnabled = false
    clearAllESP()
    if espUpdateConn then espUpdateConn:Disconnect(); espUpdateConn = nil end
end

-- Listen for new players joining while ESP is on
Players.PlayerAdded:Connect(function(p)
    if espEnabled then
        createESPForPlayer(p)
    end
end)

Players.PlayerRemoving:Connect(function(p)
    removeESPForPlayer(p)
end)

-- ========== KILL AURA SYSTEM ==========
local function startKillAura()
    if killAuraConn then killAuraConn:Disconnect() end
    savedHitboxSizes = {}

    killAuraConn = RunService.Heartbeat:Connect(function()
        if not killAuraEnabled or not player.Character then return end
        local char = player.Character
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Restore sizes for parts that are no longer in an equipped tool
        for part, origSize in pairs(savedHitboxSizes) do
            if not part.Parent or not part:IsDescendantOf(char) then
                if part.Parent then
                    part.Size = origSize
                end
                savedHitboxSizes[part] = nil
            end
        end

        -- Find equipped tool
        local equippedTool = nil
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then
                equippedTool = child
                break
            end
        end

        if not equippedTool then
            -- No tool equipped - restore all saved hitboxes
            for part, origSize in pairs(savedHitboxSizes) do
                if part.Parent then part.Size = origSize end
            end
            savedHitboxSizes = {}
            return
        end

        -- Strategy 1: Look for parts with "hitbox" or "hit" in name
        local foundHitbox = false
        for _, part in ipairs(equippedTool:GetDescendants()) do
            if part:IsA("BasePart") then
                local nameLower = part.Name:lower()
                if nameLower:find("hitbox") or nameLower:find("hit_box") or nameLower:find("hit") then
                    if not savedHitboxSizes[part] then
                        savedHitboxSizes[part] = part.Size
                    end
                    part.Size = Vector3.new(25, 25, 25)
                    foundHitbox = true
                end
            end
        end

        if not foundHitbox then
            -- Strategy 2: Find small/invisible parts (likely hitboxes)
            for _, part in ipairs(equippedTool:GetDescendants()) do
                if part:IsA("BasePart") and part ~= hrp then
                    local isVisual = false
                    -- MeshParts with meshes are usually visual
                    if part:IsA("MeshPart") and part.MeshId ~= "" then
                        isVisual = true
                    end
                    -- Parts with SpecialMesh children are visual
                    if part:FindFirstChildOfClass("SpecialMesh") then
                        isVisual = true
                    end

                    if not isVisual then
                        if not savedHitboxSizes[part] then
                            savedHitboxSizes[part] = part.Size
                        end
                        part.Size = Vector3.new(25, 25, 25)
                        foundHitbox = true
                    end
                end
            end
        end

        if not foundHitbox then
            -- Strategy 3: Enlarge ALL parts in the tool
            for _, part in ipairs(equippedTool:GetDescendants()) do
                if part:IsA("BasePart") then
                    if not savedHitboxSizes[part] then
                        savedHitboxSizes[part] = part.Size
                    end
                    part.Size = Vector3.new(25, 25, 25)
                end
            end
        end
    end)
end

local function stopKillAura()
    if killAuraConn then killAuraConn:Disconnect(); killAuraConn = nil end
    for part, origSize in pairs(savedHitboxSizes) do
        if part.Parent then part.Size = origSize end
    end
    savedHitboxSizes = {}
end

