--  CREDITS TAB
-- ==========================================
Tabs.Credits:AddParagraph({
    Title   = "LUCKY BLOCK Battlegrounds",
    Content = "Sheitsa Hub V2\nScript made by the Sheitsa Dev Team.\nAll credits go to Sheitsa Dev Team for creating this script.",
})

Tabs.Credits:AddParagraph({
    Title   = "UI Library",
    Content = "Fluent by dawid-scripts\nhttps://github.com/dawid-scripts/Fluent",
})

Tabs.Credits:AddSection("Social")

Tabs.Credits:AddButton({
    Title       = "Join our Discord",
    Description = "Copies the Discord invite link",
    Callback    = function()
        pcall(setclipboard, DiscordLink)
        Fluent:Notify({ Title = "LBB", Content = "Discord link copied!", Duration = 3 })
    end
})

-- ==========================================
--  RESPAWN PERSISTENCE
-- ==========================================
player.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.WalkSpeed = stateWalkSpeed
    humanoid.JumpPower = stateJumpPower
    task.wait(1)
    if stateNoClip then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end
end)

-- ==========================================
--  STARTUP NOTIFICATION
-- ==========================================
Fluent:Notify({
    Title   = "LBB | Sheitsa Hub V2",
    Content = "Script loaded! Press RightControl to minimize.",
    Duration = 4
})

-- ==========================================
--  DRAGGABLE TOGGLE BUTTON
-- ==========================================
local toggleGui = Instance.new("ScreenGui")
toggleGui.Name = "LBBSheitsaToggle"
toggleGui.ResetOnSpawn = false
toggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
toggleGui.Parent = CoreGui

local hubVisible = true

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 44, 0, 44)
toggleBtn.Position = UDim2.new(0.5, -22, 0, 14)
toggleBtn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
toggleBtn.Text = ""
toggleBtn.BorderSizePixel = 0
toggleBtn.AutoButtonColor = false
toggleBtn.Parent = toggleGui
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 11)

local tStroke = Instance.new("UIStroke", toggleBtn)
tStroke.Color = Color3.fromRGB(190, 190, 200)
tStroke.Thickness = 1.5

local tLabel = Instance.new("TextLabel", toggleBtn)
tLabel.Size = UDim2.new(1, 0, 1, 0)
tLabel.Text = "LB"
tLabel.TextSize = 13
tLabel.BackgroundTransparency = 1
tLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
tLabel.Font = Enum.Font.GothamBold

-- Drag + Click (with 5px drag threshold)
local htDrag, htDragStart, htStartPos, htDidDrag
toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        htDrag = true; htDidDrag = false
        htDragStart = input.Position; htStartPos = toggleBtn.Position
    end
end)
toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not htDidDrag then
            hubVisible = not hubVisible
            if fluentGui and fluentGui.Parent then
                fluentGui.Enabled = hubVisible
            end
            tLabel.Text = hubVisible and "LB" or "--"
            tStroke.Color = hubVisible and Color3.fromRGB(190, 190, 200) or Color3.fromRGB(80, 80, 90)
            toggleBtn.BackgroundColor3 = hubVisible and Color3.fromRGB(12, 12, 16) or Color3.fromRGB(30, 30, 36)
        end
        htDrag = false
    end
end)
UIS.InputChanged:Connect(function(input)
    if htDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - htDragStart
        if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then htDidDrag = true end
        toggleBtn.Position = UDim2.new(htStartPos.X.Scale, htStartPos.X.Offset + d.X, htStartPos.Y.Scale, htStartPos.Y.Offset + d.Y)
    end
end)

