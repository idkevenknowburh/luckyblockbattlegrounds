-- Card-style Button
local function makeButton(parent, text, bgColor, hoverColor, order, cb)
    local wrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 42), BackgroundColor3 = bgColor,
        BorderSizePixel = 0, LayoutOrder = order or 0,
    }, parent)
    corner(wrap, 10)
    stroke(wrap, C.BorderLight, 1)

    local btn = new("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        Text = text, TextColor3 = C.Black, TextSize = 13.5,
        Font = Enum.Font.GothamSemibold, BorderSizePixel = 0, AutoButtonColor = false,
    }, wrap)

    wrap.MouseEnter:Connect(function() tw(wrap, {BackgroundColor3 = hoverColor}, 0.2) end)
    wrap.MouseLeave:Connect(function() tw(wrap, {BackgroundColor3 = bgColor}, 0.2) end)
    if cb then btn.MouseButton1Click:Connect(cb) end
    return wrap, btn
end

-- Dropdown
local function makeDropdown(parent, label, options, default, order)
    local wrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = order or 0,
    }, parent)
    new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}, wrap)

    new("TextLabel", {
        Text = label, Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1,
        TextColor3 = C.Sub, TextSize = 11, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)

    local selected = default or options[1]
    local isOpen = false

    local selectWrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = C.InputBG, BorderSizePixel = 0,
    }, wrap)
    corner(selectWrap, 9)
    stroke(selectWrap, C.Border, 1)

    local selectBtn = new("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        Text = "  \226\149\190  " .. selected, TextColor3 = C.Text,
        TextSize = 12.5, Font = Enum.Font.Gotham, BorderSizePixel = 0,
        TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false,
    }, selectWrap)

    local listFrame = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = C.DDBg,
        BorderSizePixel = 0, ClipsDescendants = true, ZIndex = 5,
    }, wrap)
    corner(listFrame, 9)
    stroke(listFrame, C.Border, 1)
    new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder}, listFrame)

    for i, opt in ipairs(options) do
        local oBtn = new("TextButton", {
            Size = UDim2.new(1, 0, 0, 32), BackgroundColor3 = C.DDBg,
            Text = "   " .. opt, TextColor3 = C.Text, TextSize = 12,
            Font = Enum.Font.Gotham, BorderSizePixel = 0,
            TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false,
            LayoutOrder = i, ZIndex = 5,
        }, listFrame)
        oBtn.MouseEnter:Connect(function() tw(oBtn, {BackgroundColor3 = C.DDHover}, 0.12) end)
        oBtn.MouseLeave:Connect(function() tw(oBtn, {BackgroundColor3 = C.DDBg}, 0.12) end)
        oBtn.MouseButton1Click:Connect(function()
            selected = opt; selectBtn.Text = "  \226\149\190  " .. opt; isOpen = false
            tw(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        end)
    end

    selectBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        tw(listFrame, {Size = UDim2.new(1, 0, 0, isOpen and (#options * 32 + 4) or 0)}, 0.2)
    end)

    return { Get = function() return selected end }
end

-- Manual Slider
local function makeSlider(parent, label, minVal, maxVal, defaultVal, order, callback)
    local wrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = order or 0,
    }, parent)
    new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}, wrap)

    -- Label row
    local labelRow = new("Frame", {
        Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1,
    }, wrap)
    new("TextLabel", {
        Text = label, Size = UDim2.new(0.7, 0, 1, 0), BackgroundTransparency = 1,
        TextColor3 = C.Sub, TextSize = 11, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, labelRow)
    local valLabel = new("TextLabel", {
        Text = tostring(defaultVal), Size = UDim2.new(0.3, 0, 1, 0), Position = UDim2.new(0.7, 0, 0, 0),
        BackgroundTransparency = 1, TextColor3 = C.Text, TextSize = 12,
        Font = Enum.Font.GothamBold, TextXAlignment = Enum.TextXAlignment.Right,
    }, labelRow)

    -- Slider track
    local trackWrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1,
    }, wrap)

    local track = new("Frame", {
        Size = UDim2.new(1, 0, 0, 6), Position = UDim2.new(0, 0, 0.5, -3),
        BackgroundColor3 = C.SliderTrack, BorderSizePixel = 0,
    }, trackWrap)
    corner(track, 3)

    local fill = new("Frame", {
        Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = C.SliderFill, BorderSizePixel = 0,
    }, track)
    corner(fill, 3)

    local knob = new("Frame", {
        Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(0, 0, 0.5, -9),
        BackgroundColor3 = C.SliderKnob, BorderSizePixel = 0,
    }, trackWrap)
    corner(knob, 9)
    stroke(knob, C.Accent, 2)

    local currentVal = defaultVal
    local sliding = false

    local function updateVisual(val)
        local pct = (val - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -9, 0.5, -9)
        valLabel.Text = tostring(math.round(val))
    end

    updateVisual(defaultVal)

    local function setValueFromX(x)
        local relX = clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = minVal + relX * (maxVal - minVal)
        val = math.round(val)
        currentVal = val
        updateVisual(val)
        if callback then callback(val) end
    end

    trackWrap.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            setValueFromX(input.Position.X)
        end
    end)
    trackWrap.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setValueFromX(input.Position.X)
        end
    end)

    return { GetValue = function() return currentVal end, SetValue = function(v) currentVal = v; updateVisual(v) end }
end

-- Input Row (label + input + button)
local function makeInputRow(parent, labelText, defaultVal, btnText, order, callback)
    local wrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = order or 0,
    }, parent)
    new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}, wrap)

    new("TextLabel", {
        Text = labelText, Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1,
        TextColor3 = C.Sub, TextSize = 11, Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)

    local row = new("Frame", {
        Size = UDim2.new(1, 0, 0, 36), BackgroundTransparency = 1,
    }, wrap)
    new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), FillDirection = Enum.FillDirection.Horizontal}, row)

    local input = new("TextBox", {
        Size = UDim2.new(1, -110, 1, 0), BackgroundColor3 = C.InputBG, Text = defaultVal or "",
        TextColor3 = C.Text, PlaceholderText = "Enter value...", PlaceholderColor3 = Color3.fromRGB(65, 65, 80),
        TextSize = 13, Font = Enum.Font.Gotham, BorderSizePixel = 0,
    }, row)
    corner(input, 9); stroke(input, C.Border, 1)

    makeButton(row, btnText, C.Accent, C.AccentHover, 0, function()
        local v = tonumber(input.Text)
        if v then callback(v) end
    end)

    return input
end

-- Toggle
local function makeToggle(parent, label, defaultOn, order, callback)
    local wrap = new("Frame", {
        Size = UDim2.new(1, 0, 0, 44), BackgroundColor3 = C.Card,
        BorderSizePixel = 0, LayoutOrder = order or 0,
    }, parent)
    corner(wrap, 10)
    stroke(wrap, C.Border, 1)

    new("TextLabel", {
        Text = "  " .. label, Size = UDim2.new(1, -64, 1, 0), BackgroundTransparency = 1,
        TextColor3 = defaultOn and C.White or C.Sub, TextSize = 13,
        Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left,
    }, wrap)

    local toggleBg = new("Frame", {
        Size = UDim2.new(0, 44, 0, 24), Position = UDim2.new(1, -54, 0.5, -12),
        BackgroundColor3 = defaultOn and C.ToggleOn or C.ToggleOff, BorderSizePixel = 0,
    }, wrap)
    corner(toggleBg, 12)

    local dot = new("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = defaultOn and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
        BackgroundColor3 = C.White, BorderSizePixel = 0,
    }, toggleBg)
    corner(dot, 9)

    local on = defaultOn

    local btn = new("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false,
    }, wrap)

    wrap.MouseEnter:Connect(function() tw(wrap, {BackgroundColor3 = C.CardHover}, 0.15) end)
    wrap.MouseLeave:Connect(function() tw(wrap, {BackgroundColor3 = C.Card}, 0.15) end)

    btn.MouseButton1Click:Connect(function()
        on = not on
        tw(dot, {Position = on and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)}, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        tw(toggleBg, {BackgroundColor3 = on and C.ToggleOn or C.ToggleOff}, 0.25)
        -- Update text color
        for _, child in ipairs(wrap:GetChildren()) do
            if child:IsA("TextLabel") then
                tw(child, {TextColor3 = on and C.White or C.Sub}, 0.2)
            end
        end
        if callback then callback(on) end
    end)

    return { IsOn = function() return on end }
end

