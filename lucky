-- Drag for toggle button (with click threshold)
local tbDrag, tbDragStart, tbStartPos, tbDidDrag
toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        tbDrag = true; tbDidDrag = false
        tbDragStart = input.Position; tbStartPos = toggleBtn.Position
    end
end)
toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not tbDidDrag then
            if mainVisible then hideMain() else showMain() end
        end
        tbDrag = false
    end
end)
UIS.InputChanged:Connect(function(input)
    if tbDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - tbDragStart
        if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then tbDidDrag = true end
        toggleBtn.Position = UDim2.new(tbStartPos.X.Scale, tbStartPos.X.Offset + d.X, tbStartPos.Y.Scale, tbStartPos.Y.Offset + d.Y)
    end
end)

