-- ========== DEATH TRACKING ==========
local function setupDeathTracking()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end

    humanoid.Died:Connect(function()
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local myPos = hrp.Position
            local closest = nil
            local closestDist = math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
                    if dist < closestDist and dist < 150 then
                        closestDist = dist
                        closest = p
                    end
                end
            end
            if closest then
                lastKiller = closest
                lastKillerName = closest.Name
                if killerLabel then
                    killerLabel.Text = "Last killer: " .. lastKillerName
                end
            end
        end
    end)
end

-- Initial death tracking
if player.Character then
    setupDeathTracking()
end

-- ========== RESPAWN PERSISTENCE ==========
player.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.WalkSpeed = stateWalkSpeed
    humanoid.JumpPower = stateJumpPower

    -- Set up death tracking for new character
    setupDeathTracking()

    task.wait(2)

    -- Auto spawn blocks on respawn
    if autoSpawnEnabled then
        local blockMap = {
            ["Lucky Block"] = Blocks.Lucky,
            ["Super Block"] = Blocks.Super,
            ["Diamond Block"] = Blocks.Diamond,
            ["Rainbow Lucky Block"] = Blocks.Rainbow,
            ["Galaxy Lucky Block"] = Blocks.Galaxy,
        }
        local remote = blockMap[autoSpawnBlock]
        if remote then
            for i = 1, math.clamp(autoSpawnAmount, 1, 50) do
                remote:FireServer()
                if i < autoSpawnAmount then task.wait(0.1) end
            end
        end
    end

    -- Revenge kill
    if revengeKillEnabled and lastKiller then
        -- Spawn 5 galaxy blocks
        for i = 1, 5 do
            Blocks.Galaxy:FireServer()
            if i < 5 then task.wait(0.1) end
        end
        -- TP to killer
        task.wait(0.5)
        if lastKiller.Character and lastKiller.Character:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = lastKiller.Character.HumanoidRootPart.CFrame + lastKiller.Character.HumanoidRootPart.CFrame.LookVector * 3
        end
        -- Auto-untoggle (one-time use)
        revengeKillEnabled = false
        if revengeToggleCtrl then
            revengeToggleCtrl.setState(false)
        end
    end

    -- NoClip persistence
    if stateNoClip then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end
end)

