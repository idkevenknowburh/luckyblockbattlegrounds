-- ============================================
-- LUCKY BLOCK Battlegrounds - Sheitsa Hub V2
-- UI: Rayfield by Sirius
-- ============================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local RS = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local DiscordLink = "https://discord.gg/ZE6vyxgydK"

-- Wait for remotes
local Blocks = {
    Lucky   = RS:WaitForChild("SpawnLuckyBlock"),
    Super   = RS:WaitForChild("SpawnSuperBlock"),
    Diamond = RS:WaitForChild("SpawnDiamondBlock"),
    Rainbow = RS:WaitForChild("SpawnRainbowBlock"),
    Galaxy  = RS:WaitForChild("SpawnGalaxyBlock"),
}

-- ========== STATE ==========
local noclipConn = nil
local stateWalkSpeed = 16
local stateJumpPower = 50
local stateNoClip = false
local selectedBlock = "Lucky Block"
local selectedGPBlock = "Rainbow Lucky Block"
local spawnAmount = 5
local gpSpawnAmount = 3

-- ========== RAYFIELD UI ==========
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "LBB | Sheitsa Hub V2",
    Icon = 0,
    LoadingTitle = "LBB | Sheitsa Hub V2",
    LoadingSubtitle = "by Sheitsa",
    Theme = "AmberGlow",
    ToggleUIKeybind = Enum.KeyCode.RightControl,
    ConfigurationSaving = {Enabled = false},
    DisableRayfieldPrompts = true,
})

-- ==========================================
--  BLOCKS TAB
-- ==========================================
local BlocksTab = Window:CreateTab({
    Name = "Blocks",
    Icon = "box",
})

BlocksTab:CreateSection({Name = "Spawn Blocks"})

BlocksTab:CreateDropdown({
    Name = "Block Type",
    Options = {"Lucky Block", "Super Block", "Diamond Block"},
    Default = "Lucky Block",
    Callback = function(Value)
        selectedBlock = Value
    end,
})

BlocksTab:CreateButton({
    Name = "Spawn Block",
    Callback = function()
        local map = {
            ["Lucky Block"] = Blocks.Lucky,
            ["Super Block"] = Blocks.Super,
            ["Diamond Block"] = Blocks.Diamond,
        }
        local remote = map[selectedBlock]
        if remote then remote:FireServer() end
    end,
})

BlocksTab:CreateSlider({
    Name = "Spawn Amount",
    Min = 1,
    Max = 50,
    Default = 5,
    Increment = 1,
    Callback = function(Value)
        spawnAmount = Value
    end,
})

BlocksTab:CreateButton({
    Name = "Spawn Multiple",
    Callback = function()
        local map = {
            ["Lucky Block"] = Blocks.Lucky,
            ["Super Block"] = Blocks.Super,
            ["Diamond Block"] = Blocks.Diamond,
        }
        local remote = map[selectedBlock]
        if remote then
            local amount = math.clamp(spawnAmount, 1, 50)
            for i = 1, amount do
                remote:FireServer()
                if i < amount then task.wait(0.1) end
            end
        end
    end,
})

BlocksTab:CreateSection({Name = "VERY OP (Gamepass Blocks)"})

BlocksTab:CreateDropdown({
    Name = "Gamepass Block",
    Options = {"Rainbow Lucky Block", "Galaxy Lucky Block"},
    Default = "Rainbow Lucky Block",
    Callback = function(Value)
        selectedGPBlock = Value
    end,
})

BlocksTab:CreateButton({
    Name = "Spawn Gamepass Block",
    Callback = function()
        local map = {
            ["Rainbow Lucky Block"] = Blocks.Rainbow,
            ["Galaxy Lucky Block"] = Blocks.Galaxy,
        }
        local remote = map[selectedGPBlock]
        if remote then remote:FireServer() end
    end,
})

BlocksTab:CreateSlider({
    Name = "GP Spawn Amount",
    Min = 1,
    Max = 50,
    Default = 3,
    Increment = 1,
    Callback = function(Value)
        gpSpawnAmount = Value
    end,
})

BlocksTab:CreateButton({
    Name = "Spawn Multiple (GP)",
    Callback = function()
        local map = {
            ["Rainbow Lucky Block"] = Blocks.Rainbow,
            ["Galaxy Lucky Block"] = Blocks.Galaxy,
        }
        local remote = map[selectedGPBlock]
        if remote then
            local amount = math.clamp(gpSpawnAmount, 1, 50)
            for i = 1, amount do
                remote:FireServer()
                if i < amount then task.wait(0.1) end
            end
        end
    end,
})

-- ==========================================
--  UNIVERSAL TAB
-- ==========================================
local UniversalTab = Window:CreateTab({
    Name = "Universal",
    Icon = "user",
})

UniversalTab:CreateSection({Name = "Movement"})

UniversalTab:CreateSlider({
    Name = "WalkSpeed",
    Min = 10,
    Max = 200,
    Default = 16,
    Increment = 1,
    Callback = function(Value)
        stateWalkSpeed = Value
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = Value
        end
    end,
})

UniversalTab:CreateSlider({
    Name = "JumpPower",
    Min = 10,
    Max = 500,
    Default = 50,
    Increment = 1,
    Callback = function(Value)
        stateJumpPower = Value
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.JumpPower = Value
        end
    end,
})

UniversalTab:CreateSection({Name = "Physics"})

UniversalTab:CreateToggle({
    Name = "NoClip",
    Default = false,
    Callback = function(Value)
        stateNoClip = Value
        if Value then
            noclipConn = RunService.Stepped:Connect(function()
                if player.Character then
                    for _, p in ipairs(player.Character:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                end
            end)
        else
            if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end
        end
    end,
})

UniversalTab:CreateSection({Name = "Tools"})

UniversalTab:CreateButton({
    Name = "Infinite Yield",
    Callback = function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source", true))()
    end,
})

-- ==========================================
--  CREDITS TAB
-- ==========================================
local CreditsTab = Window:CreateTab({
    Name = "Credits",
    Icon = "heart",
})

CreditsTab:CreateParagraph({
    Title = "LUCKY BLOCK Battlegrounds",
    Content = "Sheitsa Hub V2\nScript made by the Sheitsa Dev Team.\nAll credits go to Sheitsa Dev Team for creating this script.",
})

CreditsTab:CreateParagraph({
    Title = "UI Library",
    Content = "Rayfield by Sirius\nhttps://sirius.menu",
})

CreditsTab:CreateSection({Name = "Social"})

CreditsTab:CreateButton({
    Name = "Join our Discord",
    Callback = function()
        pcall(setclipboard, DiscordLink)
        Rayfield:Notify({Title = "LBB", Content = "Discord link copied!", Duration = 3})
    end,
})

-- ==========================================
--  RESPAWN PERSISTENCE
-- ==========================================
player.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.WalkSpeed = stateWalkSpeed
    humanoid.JumpPower = stateJumpPower
    task.wait(1)
    if stateNoClip then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end
end)

-- ==========================================
--  STARTUP NOTIFICATION
-- ==========================================
Rayfield:Notify({
    Title = "LBB | Sheitsa Hub V2",
    Content = "Script loaded! Press RightControl to toggle.",
    Duration = 4,
})

-- ==========================================
--  DRAGGABLE TOGGLE BUTTON
-- ==========================================
local toggleGui = Instance.new("ScreenGui")
toggleGui.Name = "LBBSheitsaToggle"
toggleGui.ResetOnSpawn = false
toggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
toggleGui.Parent = CoreGui

local hubVisible = true

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 44, 0, 44)
toggleBtn.Position = UDim2.new(0.5, -22, 0, 14)
toggleBtn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
toggleBtn.Text = ""
toggleBtn.BorderSizePixel = 0
toggleBtn.AutoButtonColor = false
toggleBtn.Parent = toggleGui
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 11)

local tStroke = Instance.new("UIStroke", toggleBtn)
tStroke.Color = Color3.fromRGB(190, 190, 200)
tStroke.Thickness = 1.5

local tLabel = Instance.new("TextLabel", toggleBtn)
tLabel.Size = UDim2.new(1, 0, 1, 0)
tLabel.Text = "LB"
tLabel.TextSize = 13
tLabel.BackgroundTransparency = 1
tLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
tLabel.Font = Enum.Font.GothamBold

-- Drag + Click (with 5px drag threshold)
local htDrag, htDragStart, htStartPos, htDidDrag
toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        htDrag = true; htDidDrag = false
        htDragStart = input.Position; htStartPos = toggleBtn.Position
    end
end)
toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not htDidDrag then
            hubVisible = not hubVisible
            Rayfield:SetVisibility(hubVisible)
            tLabel.Text = hubVisible and "LB" or "--"
            tStroke.Color = hubVisible and Color3.fromRGB(190, 190, 200) or Color3.fromRGB(80, 80, 90)
            toggleBtn.BackgroundColor3 = hubVisible and Color3.fromRGB(12, 12, 16) or Color3.fromRGB(30, 30, 36)
        end
        htDrag = false
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if htDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - htDragStart
        if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then htDidDrag = true end
        toggleBtn.Position = UDim2.new(htStartPos.X.Scale, htStartPos.X.Offset + d.X, htStartPos.Y.Scale, htStartPos.Y.Offset + d.Y)
    end
end)

warn("[LBB Sheitsa Hub V2] >> Loaded with Rayfield UI!")
