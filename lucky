local function switchTab(name)
    for n, frame in pairs(tabFrames) do
        if n == name then
            frame.Visible = true
            frame.BackgroundTransparency = 0.5
            tw(frame, {BackgroundTransparency = 0}, 0.2)
        else
            frame.Visible = false
        end
    end
    for n, btn in pairs(tabButtons) do
        local active = (n == name)
        tw(btn, {
            BackgroundColor3 = active and C.TabActive or C.TabInactive,
            TextColor3 = active and C.Black or C.Sub,
        }, 0.25)
    end
end

