-- Slider
local function makeSlider(parent, title, min, max, default, callback, order)
    local container = new("Frame", parent, {
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundTransparency = 1,
        LayoutOrder = order,
        BorderSizePixel = 0,
    })

    -- Title label
    new("TextLabel", container, {
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, -50, 0, 18),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = C.Text,
        TextSize = 12,
        Font = Enum.Font.GothamSemibold,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Value label
    local valueLabel = new("TextLabel", container, {
        Position = UDim2.new(1, -48, 0, 0),
        Size = UDim2.new(0, 48, 0, 18),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = C.Accent,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    -- Track
    local track = new("Frame", container, {
        Position = UDim2.new(0, 0, 0, 36),
        Size = UDim2.new(1, 0, 0, 4),
        BackgroundColor3 = C.SliderTrack,
        BorderSizePixel = 0,
    })
    new("UICorner", track, { CornerRadius = UDim.new(0, 2) })

    -- Fill
    local fill = new("Frame", track, {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = C.Accent,
        BorderSizePixel = 0,
    })
    new("UICorner", fill, { CornerRadius = UDim.new(0, 2) })

    -- Circle handle
    local circle = new("Frame", container, {
        Size = UDim2.new(0, 14, 0, 14),
        BackgroundColor3 = C.Accent,
        ZIndex = 3,
        BorderSizePixel = 0,
    })
    new("UICorner", circle, { CornerRadius = UDim.new(0, 7) })

    local dragging = false
    local value = default

    local function updateVisual()
        local pct = (value - min) / (max - min)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        circle.Position = UDim2.new(pct, -7, 0, 31)
        valueLabel.Text = tostring(math.round(value))
    end

    -- Hidden button on circle for input capture
    local inputBtn = new("TextButton", circle, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 4,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })

    -- Hidden button on track for click-to-set
    local trackBtn = new("TextButton", track, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 2,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })

    local function calculateValue(mouseX)
        local trackW = track.AbsoluteSize.X
        if trackW <= 0 then return end
        local relX = mouseX - track.AbsolutePosition.X
        local pct = relX / trackW
        pct = math.clamp(pct, 0, 1)
        local newVal = min + pct * (max - min)
        newVal = math.round(newVal)
        if newVal ~= value then
            value = newVal
            updateVisual()
            callback(value)
        end
    end

    inputBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)

    trackBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            calculateValue(input.Position.X)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            calculateValue(input.Position.X)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
            end
        end
    end)

    updateVisual()

    return container
end

-- Dropdown
local function makeDropdown(parent, title, options, default, callback, order)
    local header = new("TextButton", parent, {
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = C.Card,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    new("UICorner", header, { CornerRadius = UDim.new(0, 8) })
    new("UIStroke", header, { Color = C.Border, Thickness = 1 })

    -- Selected text
    local selectedLabel = new("TextLabel", header, {
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -30, 1, 0),
        BackgroundTransparency = 1,
        Text = default,
        TextColor3 = C.Text,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Arrow
    local arrow = new("TextLabel", header, {
        Position = UDim2.new(1, -24, 0, 0),
        Size = UDim2.new(0, 24, 1, 0),
        BackgroundTransparency = 1,
        Text = "\u{25BC}",
        TextColor3 = C.TextSub,
        TextSize = 12,
        Font = Enum.Font.Gotham,
    })

    -- Options container (overlays below header)
    local optionsFrame = new("Frame", header, {
        Position = UDim2.new(0, 0, 1, 2),
        Size = UDim2.new(1, 0, 0, #options * 32),
        BackgroundColor3 = C.Card,
        Visible = false,
        ZIndex = 10,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    })
    new("UICorner", optionsFrame, { CornerRadius = UDim.new(0, 8) })
    new("UIStroke", optionsFrame, { Color = C.Border, Thickness = 1 })

    local isOpen = false

    local function close()
        isOpen = false
        optionsFrame.Visible = false
        arrow.Text = "\u{25BC}"
    end

    for i, opt in ipairs(options) do
        local optBtn = new("TextButton", optionsFrame, {
            Position = UDim2.new(0, 4, 0, (i - 1) * 32 + 1),
            Size = UDim2.new(1, -8, 0, 30),
            BackgroundColor3 = C.Card,
            Text = opt,
            TextColor3 = C.Text,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            BorderSizePixel = 0,
            ZIndex = 11,
            AutoButtonColor = false,
        })

        optBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                optBtn.BackgroundColor3 = C.CardHover
            end
        end)

        optBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                optBtn.BackgroundColor3 = C.Card
            end
        end)

        optBtn.MouseButton1Click:Connect(function()
            selectedLabel.Text = opt
            callback(opt)
            close()
            local idx = table.find(openDropdowns, close)
            if idx then table.remove(openDropdowns, idx) end
        end)
    end

    header.MouseButton1Click:Connect(function()
        local wasOpen = isOpen

        -- Close all other open dropdowns
        local toClose = { table.unpack(openDropdowns) }
        for _, fn in ipairs(toClose) do
            fn()
        end
        openDropdowns = {}

        -- Toggle this dropdown
        if not wasOpen then
            isOpen = true
            optionsFrame.Visible = true
            arrow.Text = "\u{25B2}"
            table.insert(openDropdowns, close)
        end
    end)

    return header
end

