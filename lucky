-- ========== TAB SWITCHING ==========
switchTab = function(name)
    -- Close any open dropdowns
    local toClose = { table.unpack(openDropdowns) }
    for _, fn in ipairs(toClose) do
        fn()
    end
    openDropdowns = {}

    for tabName, page in pairs(tabPages) do
        page.Visible = (tabName == name)
        if tabName == name then
            page.CanvasPosition = Vector2.new(0, 0)
        end
    end
    for tabName, data in pairs(tabButtons) do
        local isActive = (tabName == name)
        data.button.BackgroundColor3 = isActive and C.CardHover or Color3.fromRGB(0, 0, 0)
        data.button.BackgroundTransparency = isActive and 0 or 1
        data.indicator.Visible = isActive
        data.button.TextColor3 = isActive and C.Text or C.TextSub
    end
end

