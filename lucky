local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local RS = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local DiscordLink = "https://discord.gg/ZE6vyxgydK"

-- Wait for remotes
local Blocks = {
    Lucky   = RS:WaitForChild("SpawnLuckyBlock"),
    Super   = RS:WaitForChild("SpawnSuperBlock"),
    Diamond = RS:WaitForChild("SpawnDiamondBlock"),
    Rainbow = RS:WaitForChild("SpawnRainbowBlock"),
    Galaxy  = RS:WaitForChild("SpawnGalaxyBlock"),
}

-- ========== STATE ==========
local noclipConn = nil
local stateWalkSpeed = 16
local stateJumpPower = 50
local stateNoClip = false
local selectedBlock = "Lucky Block"
local selectedGPBlock = "Rainbow Lucky Block"
local spawnAmount = 5
local gpSpawnAmount = 3

-- ========== FLUENT UI ==========
local Fluent = loadstring(game:HttpGet("https://github.com/StyearX/Fluent-Modded/releases/download/Fluent/FluentPro"))()

local Window = Fluent:CreateWindow({
    Title       = "LBB | Sheitsa Hub V2",
    SubTitle    = "by Sheitsa",
    TabWidth    = 120,
    Size        = UDim2.fromOffset(550, 420),
    Acrylic     = true,
    Theme       = "AMOLED",
    MinimizeKey = Enum.KeyCode.RightControl,
    ConfigurationSaving = {
        Enabled = false,
    },
})

local Tabs = {
    Blocks    = Window:AddTab({ Title = "Blocks",    Icon = "box" }),
    Universal = Window:AddTab({ Title = "Universal", Icon = "user" }),
    Credits   = Window:AddTab({ Title = "Credits",   Icon = "heart" }),
}

-- ==========================================
--  BLOCKS TAB
-- ==========================================
Tabs.Blocks:AddSection("Spawn Blocks")

Tabs.Blocks:AddDropdown({
    Title       = "Block Type",
    Description = "Select which block to spawn",
    Values      = {"Lucky Block", "Super Block", "Diamond Block"},
    Default     = "Lucky Block",
    Callback    = function(Value)
        selectedBlock = Value
    end
})

Tabs.Blocks:AddButton({
    Title       = "Spawn Block",
    Description = "Spawns the selected block type",
    Callback    = function()
        local map = {
            ["Lucky Block"] = Blocks.Lucky,
            ["Super Block"] = Blocks.Super,
            ["Diamond Block"] = Blocks.Diamond,
        }
        local remote = map[selectedBlock]
        if remote then remote:FireServer() end
    end
})

Tabs.Blocks:AddSlider({
    Title       = "Spawn Amount",
    Description = "How many blocks to spawn (1-50)",
    Min         = 1,
    Max         = 50,
    Default     = 5,
    Callback    = function(Value)
        spawnAmount = Value
    end
})

Tabs.Blocks:AddButton({
    Title       = "Spawn Multiple",
    Description = "Spawns the selected amount of blocks",
    Callback    = function()
        local map = {
            ["Lucky Block"] = Blocks.Lucky,
            ["Super Block"] = Blocks.Super,
            ["Diamond Block"] = Blocks.Diamond,
        }
        local remote = map[selectedBlock]
        if remote then
            local amount = math.clamp(spawnAmount, 1, 50)
            for i = 1, amount do
                remote:FireServer()
                if i < amount then task.wait(0.1) end
            end
        end
    end
})

Tabs.Blocks:AddSection("VERY OP (Gamepass Blocks)")

Tabs.Blocks:AddDropdown({
    Title       = "Gamepass Block",
    Description = "Select gamepass block",
    Values      = {"Rainbow Lucky Block", "Galaxy Lucky Block"},
    Default     = "Rainbow Lucky Block",
    Callback    = function(Value)
        selectedGPBlock = Value
    end
})

Tabs.Blocks:AddButton({
    Title       = "Spawn Gamepass Block",
    Description = "Spawns the selected gamepass block",
    Callback    = function()
        local map = {
            ["Rainbow Lucky Block"] = Blocks.Rainbow,
            ["Galaxy Lucky Block"] = Blocks.Galaxy,
        }
        local remote = map[selectedGPBlock]
        if remote then remote:FireServer() end
    end
})

Tabs.Blocks:AddSlider({
    Title       = "GP Spawn Amount",
    Description = "How many GP blocks (1-50)",
    Min         = 1,
    Max         = 50,
    Default     = 3,
    Callback    = function(Value)
        gpSpawnAmount = Value
    end
})

Tabs.Blocks:AddButton({
    Title       = "Spawn Multiple (GP)",
    Description = "Spawns the selected amount of GP blocks",
    Callback    = function()
        local map = {
            ["Rainbow Lucky Block"] = Blocks.Rainbow,
            ["Galaxy Lucky Block"] = Blocks.Galaxy,
        }
        local remote = map[selectedGPBlock]
        if remote then
            local amount = math.clamp(gpSpawnAmount, 1, 50)
            for i = 1, amount do
                remote:FireServer()
                if i < amount then task.wait(0.1) end
            end
        end
    end
})

-- ==========================================
--  UNIVERSAL TAB
-- ==========================================
Tabs.Universal:AddSection("Movement")

Tabs.Universal:AddSlider({
    Title       = "WalkSpeed",
    Description = "Sets walk speed (persists on respawn)",
    Min         = 10,
    Max         = 200,
    Default     = 16,
    Callback    = function(Value)
        stateWalkSpeed = Value
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = Value
        end
    end
})

Tabs.Universal:AddSlider({
    Title       = "JumpPower",
    Description = "Sets jump power (persists on respawn)",
    Min         = 10,
    Max         = 500,
    Default     = 50,
    Callback    = function(Value)
        stateJumpPower = Value
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.JumpPower = Value
        end
    end
})

Tabs.Universal:AddSection("Physics")

Tabs.Universal:AddToggle({
    Title       = "NoClip",
    Description = "Walk through walls (persists on respawn)",
    Default     = false,
    Callback    = function(Value)
        stateNoClip = Value
        if Value then
            noclipConn = RunService.Stepped:Connect(function()
                if player.Character then
                    for _, p in ipairs(player.Character:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                end
            end)
        else
            if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end
        end
    end
})

Tabs.Universal:AddSection("Tools")

Tabs.Universal:AddButton({
    Title       = "Infinite Yield",
    Description = "Loads Infinite Yield admin hub",
    Callback    = function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source", true))()
    end
})

-- ==========================================
--  CREDITS TAB
-- ==========================================
Tabs.Credits:AddParagraph({
    Title   = "LUCKY BLOCK Battlegrounds",
    Content = "Sheitsa Hub V2\nScript made by the Sheitsa Dev Team.\nAll credits go to Sheitsa Dev Team for creating this script.",
})

Tabs.Credits:AddParagraph({
    Title   = "UI Library",
    Content = "Fluent-Modded by StyearX on YouTube\nhttps://github.com/StyearX/Fluent-Modded",
})

Tabs.Credits:AddSection("Social")

Tabs.Credits:AddButton({
    Title       = "Join our Discord",
    Description = "Copies the Discord invite link",
    Callback    = function()
        pcall(setclipboard, DiscordLink)
        Fluent:Notify({ Title = "LBB", Content = "Discord link copied!", Duration = 3 })
    end
})

-- ==========================================
--  RESPAWN PERSISTENCE
-- ==========================================
player.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.WalkSpeed = stateWalkSpeed
    humanoid.JumpPower = stateJumpPower
    task.wait(1)
    if stateNoClip then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            if player.Character then
                for _, p in ipairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    end
end)

