-- Toggle button drag logic with 5px threshold
local tbDragging = false
local tbDragStart = Vector3.zero
local tbStartPos = UDim2.new()
local tbDidDrag = false

toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        tbDragging = true
        tbDidDrag = false
        tbDragStart = input.Position
        tbStartPos = toggleBtn.Position
    end
end)

toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not tbDidDrag then
            screenGui.Enabled = not screenGui.Enabled
        end
        tbDragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if tbDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - tbDragStart
        if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
            tbDidDrag = true
        end
        toggleBtn.Position = UDim2.new(
            tbStartPos.X.Scale, tbStartPos.X.Offset + delta.X,
            tbStartPos.Y.Scale, tbStartPos.Y.Offset + delta.Y
        )
    end
end)

